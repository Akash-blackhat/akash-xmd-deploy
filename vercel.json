{
    "name": "akash-xmd-deploy",
    "version": 2,
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/$1.html"
        }
    ],
    "headers": [
        {
            "source": "/(.*)",
            "headers": [
                {
                    "key": "X-Content-Type-Options",
                    "value": "nosniff"
                },
                {
                    "key": "X-Frame-Options",
                    "value": "DENY"
                }
            ]
        }
    ]
}
